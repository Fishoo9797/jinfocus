/* pages/history/history.wxss */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 8rpx 24rpx;
}
.title { font-size: 40rpx; font-weight: 700; }
.filter {
  display: flex;
  background: #ece3d6;
  border-radius: 30rpx;
  padding: 4rpx;
}
.tab {
  font-size: 26rpx;
  color: #8a7a68;
  padding: 8rpx 26rpx;
  border-radius: 26rpx;
}
.tab.on {
  background: #fff;
  color: #c08552;
  font-weight: 600;
}

.day-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 14rpx;
  border-bottom: 1rpx solid #f0e9dd;
  padding-bottom: 12rpx;
}
.day-date { font-size: 28rpx; font-weight: 600; color: #4a4036; }
.day-author { font-size: 24rpx; color: #c08552; }

.q-line { margin-bottom: 10rpx; display: flex; }
.q-label { color: #c08552; font-weight: 700; margin-right: 10rpx; }
.q-text { flex: 1; color: #4a4036; word-break: break-all; }
.voice-tag {
  display: inline-block;
  margin-top: 8rpx;
  background: #faf6ef;
  color: #c08552;
  font-size: 26rpx;
  padding: 10rpx 22rpx;
  border-radius: 30rpx;
}
.link { color: #c08552; font-weight: 600; margin-top: 16rpx; }
